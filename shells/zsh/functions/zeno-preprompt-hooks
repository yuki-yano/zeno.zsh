#autoload

function zeno-preprompt-hooks() {
  emulate -L zsh

  autoload -Uz add-zle-hook-widget

  if [[ ${ZENO_PREPROMPT_HOOK_INITIALIZED-} == 1 ]]; then
    return
  fi
  typeset -g ZENO_PREPROMPT_HOOK_INITIALIZED=1

  # zle-line-init is installed after autosuggestions/highlighters have already
  # wrapped widgets in many setups. Keep autosuggestions away from that special
  # widget to avoid recursive wrapper chains.
  typeset -ga ZSH_AUTOSUGGEST_IGNORE_WIDGETS
  if (( ${ZSH_AUTOSUGGEST_IGNORE_WIDGETS[(I)zle-line-init]} == 0 )); then
    ZSH_AUTOSUGGEST_IGNORE_WIDGETS+=(zle-line-init)
  fi

  function zeno-preprompt-line-init() {
    emulate -L zsh

    if [[ -z ${ZENO_PREPROMPT_BUFFER-} ]]; then
      return
    fi

    if [[ -n $BUFFER ]]; then
      return
    fi

    BUFFER=$ZENO_PREPROMPT_BUFFER
    if [[ -n ${ZENO_PREPROMPT_CURSOR-} ]]; then
      CURSOR=$ZENO_PREPROMPT_CURSOR
    else
      CURSOR=${#BUFFER}
    fi
  }

  local -a line_init_widgets
  if zstyle -a zle-line-init widgets line_init_widgets 2>/dev/null; then
    line_init_widgets=(
      ${line_init_widgets:#(<->:|)user:_zsh_highlight_widget_orig-*-zle-line-init}
    )
    line_init_widgets=(
      ${line_init_widgets:#(<->:|)user:_zsh_autosuggest_*-zle-line-init}
    )
    if [[ -z ${(M)line_init_widgets[@]:#(<->:|)zeno-preprompt-line-init} ]]; then
      local hook_entry
      local -i max_index=0
      for hook_entry in "${line_init_widgets[@]}"; do
        if [[ $hook_entry == <->:* ]]; then
          local -i hook_index=${hook_entry%%:*}
          (( hook_index > max_index )) && max_index=$hook_index
        fi
      done
      line_init_widgets+=("$(( max_index + 1 )):zeno-preprompt-line-init")
    fi
    zstyle zle-line-init widgets "${line_init_widgets[@]}"
    if (( ! ${+widgets[zeno-preprompt-line-init]} )); then
      zle -N -- zeno-preprompt-line-init
    fi
  else
    add-zle-hook-widget line-init zeno-preprompt-line-init
  fi
}
